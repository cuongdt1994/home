# =============================================================================
# AI Shield — Environment Configuration
# Copy to .env and fill in your values. NEVER commit .env to git.
# =============================================================================

# --- Core ---
DRY_RUN=true
DEBUG=false
LOG_LEVEL=INFO

# --- Paths ---
EVE_JSON_PATH=/var/log/suricata/eve.json
WHITELIST_PATH=/app/config/whitelist.txt
THRESHOLDS_PATH=/app/config/thresholds.yaml
DATABASE_PATH=/data/shield.db
AUDIT_LOG_PATH=/logs/audit.log

# --- DeepSeek AI ---
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=8
AI_MAX_CONCURRENT_REQUESTS=2
AI_BLOCK_RISK_SCORE=8

# --- MikroTik ---
MIKROTIK_HOST=10.100.101.1
MIKROTIK_PORT=22
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=your-mikrotik-password
MIKROTIK_BLACKLIST_TIMEOUT=7d

# --- ntopng ---
NTOPNG_BASE_URL=http://10.100.101.250:3000
NTOPNG_USER=admin
NTOPNG_PASSWORD=your-ntopng-password

# --- Auth (generate with: python -c "import secrets; print(secrets.token_hex(32))") ---
JWT_SECRET=change-me-to-a-random-64-char-hex-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
TOTP_ISSUER=AI-Shield

# --- Retention ---
RETENTION_ALERT_DAYS=7
RETENTION_AI_REPORT_DAYS=30
RETENTION_AUDIT_DAYS=90
PRUNE_INTERVAL_HOURS=6

# --- Telegram (optional — leave empty to disable) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Whitelist ---
WHITELIST_CIDRS=10.100.101.0/24,192.168.0.0/16,172.16.0.0/12
